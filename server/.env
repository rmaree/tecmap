# GTFS cache server configuration

# server port (by default 3000)
PORT=3000

# the real-time API end-point
RT_VEHICLE_API_URL='https://gtfsrt.tectime.be/proto/RealTime/vehicles?key=XXXXXXXXXXXXXXXXXXX'
RT_ALERT_API_URL='https://gtfsrt.tectime.be/proto/realtime/Alerts?key=XXXXXXXXXXXXXXXXXXX'
RT_UPDATE_API_URL='https://gtfsrt.tectime.be/proto/RealTime/trips?key=XXXXXXXXXXXXXXXXXXX'

# refresh rate to call api
RT_REFRESH_RATE=10000


#logging
VERBOSE_LOGGING=false